PORT=
DB_USER=
DB_HOST=
DB_NAME=
DB_PASSWORD=
DB_PORT=
NODE_ENV=

# Google Calendar OAuth (see https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match an "Authorized redirect URI" on the OAuth client
GOOGLE_REDIRECT_URI=https://your-domain.com/api/calendar/oauth2callback
# Public HTTPS address Google will POST push notifications to.
# The domain must be verified in Google Search Console and linked to this
# GCP project (APIs & Services > Domain verification), or watch() will fail.
CALENDAR_WEBHOOK_URL=https://your-domain.com/api/calendar/webhook